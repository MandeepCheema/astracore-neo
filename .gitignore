# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/

# Virtual environment
.venv/
.venv-*/
venv/
env/

# Model artifacts — rebuild via scripts/export_yolov8n_onnx.py
data/models/*.onnx
data/models/*.pt
data/models/*.bin

# Pruned model variants — rebuild via scripts/prune_yolov8n_nm.py
data/models/pruned/*.onnx

# Calibration tensors — rebuild via scripts/fetch_yolo_calibration.py
data/calibration/*.npz

# ASIC build run logs — large + regenerable
asic/reports/*_run.log

# Probe artefacts — regenerable via scripts/int2_baseline_probe.py
reports/int2_probe_artefacts/

# cocotb / Icarus simulation artifacts
sim_build/
results.xml
*.vvp
*.vcd
*.lxt
*.fst
dump.vcd

# Logs (keep structure, ignore content)
logs/*.log

# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp
*.swo

# Vivado
.Xil/
vivado.jou
vivado.log
vivado_*.backup.*
clockInfo.txt
dfx_runtime.txt

# FPGA build outputs
fpga/output/
fpga/reports/

# ASIC build artifacts (keep configs + scripts, drop runs)
asic/runs/
asic/logs/

# Simulation build outputs (cocotb runner)
sim/*/sim_build/
sim/*/sim_build_*/
sim/*/__pycache__/
sim/*/results.xml
sim/*/dump.vcd
sim/rtl/
data/models/zoo/int8/*.onnx

# C++ runtime build artefacts
cpp/build/
cpp/*.so
cpp/*.dylib
cpp/*.pyd
cpp/*.dll
cpp/*.egg-info/

# Qualcomm AI Hub cleaned-opset intermediates
data/models/*.cleaned.onnx
data/models/zoo/*.cleaned.onnx
reports/qualcomm_aihub/*_raw.json

# AI Hub prep intermediates (not reproducible without network)
data/models/**/*.aihub.onnx
data/models/**/*.modern.onnx

# Raw ONNX zoo (reproducible via scripts/fetch_model_zoo.py)
data/models/zoo/*.onnx

# Optimum ONNX exports (heavy; regen via `optimum-cli export onnx ...`)
data/models/zoo/optimum_exports/
